# Earth-observation fusion (Phase 1)
# NASA FIRMS active fire — free MAP_KEY: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=your_firms_map_key_here
# Default coarse location when no Cloudflare geo headers are present (lat,lng)
DEFAULT_LAT=20
DEFAULT_LNG=0
# Phase 2 (Copernicus/Sentinel) — leave blank until registered
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
# NASA Earthdata bearer token (optional; cloud-DAAC/Harmony future use)
EARTHDATA_TOKEN=
# ECDSA P-256 private key (base64 of a PKCS8 PEM) for offline-verifiable prediction
# provenance. STABLE across restarts so cached client public keys keep verifying.
# Generate: node -e "const c=require('crypto');const{privateKey}=c.generateKeyPairSync('ec',{namedCurve:'P-256'});process.stdout.write(Buffer.from(privateKey.export({format:'pem',type:'pkcs8'})).toString('base64'))"
# If left blank, the server generates an ephemeral key per process (verification still
# works within a run, but the public key changes on restart).
EO_SIGNING_KEY=
